
# 服务器与目录
DOCS_DIR=C:\Pthon_Dir\PMI_Test_Tranining            # Windows 示例；macOS/Linux 用 /Users/simon/TrainingDocs
SERVER_HOST=10.200.147.157                 # 监听全部网卡，供内网访问
SERVER_PORT=8000
SERVER_PUBLIC_URL=http://10.200.147.157:8000                  # 可选；用于邮件里生成链接。如: http://192.168.1.23:8000

# 访问保护（可选：开启则需要登录）
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=123456

# 邮件（Microsoft 365 示例）
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587                       # 587=TLS；465=SSL（若改 465，也请把 USE_SSL=true）
SMTP_USERNAME=simon.huo@flex.com
SMTP_PASSWORD=123456     # 建议用“应用专用密码”，避免主密码
EMAIL_FROM=simon.huo@flex.com
EMAIL_TO=simon.huo@flex.com,
USE_TLS=true
USE_SSL=false

# 其他
AGGREGATE_SECONDS=15                # 聚合新增事件再发一封邮件，避免群发
PRIORITY_LEVEL=high                 # high / normal（跨平台最佳实践）

