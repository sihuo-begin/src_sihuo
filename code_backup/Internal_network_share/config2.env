
# 服务监听
HOST=10.200.147.81
PORT=8000

# 存储目录（默认在项目下的 uploads，可改到你磁盘的任意路径）
UPLOAD_DIR=C:\Pthon_Dir\PMI_Test_Tranining
#UPLOAD_DIR=PMI_Test_Tranining
MAX_UPLOAD_MB=500

# 访问认证（HTTP Basic Auth）
AUTH_USERNAME=admin
AUTH_PASSWORD=123

# 可选：用于在邮件里拼接可点击的完整链接（例如 https://files.example.com ）
BASE_URL=https:10.200.147.81:8000//files.example.com

# 邮件通知（Office 365 / 企业邮 / QQ/163 邮等）
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your_account@yourdomain.com
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM=your_account@yourdomain.com
SMTP_TO=alice@yourdomain.com,bob@yourdomain.com
# 是否把上传文件随邮件附上（大文件不建议）
EMAIL_ATTACH_FILE=false
